<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar categoría — HelpDesk IntegralTI</title>
    <link rel="stylesheet" href="/css/estilos.css">
</head>
<script>
    function toggleSidebar() {
        document.querySelector('.sidebar-links').classList.toggle('abierto');
    }
</script>
<body>
<div class="layout">

    <aside class="sidebar">
        <div class="sidebar-marca">
            <h1>HelpDesk IntegralTI</h1>
            <span>Panel técnico</span>
        </div>
        <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <nav class="sidebar-links">
            <a href="/tecnico/tickets">Todos los tickets</a>
            <a href="/tecnico/usuarios">Usuarios</a>
            <a href="/tecnico/categorias" class="activo">Categorías</a>
            <a href="/tecnico/perfil">Mi perfil</a>
            <a href="/logout">Cerrar sesión</a>
        </nav>
        <div class="sidebar-usuario">
            <strong><%= usuario.nombre %> <%= usuario.apellido %></strong>
            Técnico
        </div>
    </aside>

    <div class="contenido-principal">
        <main class="contenedor">
            <div class="cabecera-seccion">
                <h1>Editar categoría</h1>
                <a href="/tecnico/categorias" class="btn-secundario">Volver</a>
            </div>

            <% if (error) { %>
                <p class="error"><%= error %></p>
            <% } %>

            <form method="POST" action="/tecnico/categorias/<%= categoria.id_categoria %>/editar"
                class="formulario">
                <div class="campo">
                    <label for="nombre_categoria">Nombre *</label>
                    <input type="text" id="nombre_categoria" name="nombre_categoria"
                        value="<%= categoria.nombre_categoria %>" required>
                </div>
                <div class="campo">
                    <label for="descripcion">Descripción</label>
                    <input type="text" id="descripcion" name="descripcion"
                        value="<%= categoria.descripcion || '' %>">
                </div>
                <div class="acciones-formulario">
                    <a href="/tecnico/categorias" class="btn-secundario">Cancelar</a>
                    <button type="submit" class="btn-primario">Guardar cambios</button>
                </div>
            </form>
        </main>
    </div>

</div>
</body>
</html>
